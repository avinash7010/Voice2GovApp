# Voice2Gov Environment Configuration - v2.0
# Copy this file to .env and fill in your values

# ─── Application ────────────────────────────────────────────
APP_NAME=Voice2Gov
APP_VERSION=2.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# ─── MongoDB ─────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DATABASE_NAME=voice2gov_db

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Admin seed ──────────────────────────────────────────────
ADMIN_EMAIL=admin@voice2gov.com
ADMIN_PASSWORD=Admin@123456

# ─── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10

# ─── File Storage (Cloudinary – preferred) ───────────────────
# Sign up at https://cloudinary.com/ (free tier available)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── File Storage (AWS S3 – fallback) ────────────────────────
# Leave empty to use local uploads/ folder in dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# ─── Image Validation ────────────────────────────────────────
MAX_IMAGE_SIZE=5242880
