# =====================================================================
# Voice2Gov Environment Configuration – v2.1 (Security Hardened)
# =====================================================================
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in ALL required values (marked REQUIRED)
#   3. The app WILL NOT START with missing or placeholder secrets
#
# NEVER commit the .env file to version control!
# =====================================================================

# ─── Application ────────────────────────────────────────────────────
APP_NAME=Voice2Gov
APP_VERSION=2.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# ─── MongoDB (REQUIRED) ────────────────────────────────────────────
# Get your connection string from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
#
# ⚠️  CRITICAL SECURITY:
#   - DO NOT hardcode credentials in your code or commit credentials to Git
#   - Rotate your password immediately if ever exposed
#   - Use environment variables in production (AWS Secrets Manager, GitHub Secrets, HashiCorp Vault)
#
MONGO_URL=
DATABASE_NAME=voice2gov

# ─── JWT (REQUIRED) ────────────────────────────────────────────────
# Generate a strong key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 32 characters. NEVER use "change-me" or similar.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Admin Seed (REQUIRED) ─────────────────────────────────────────
# The initial admin account. Must be at least 12 characters.
ADMIN_EMAIL=admin@voice2gov.com
ADMIN_PASSWORD=

# ─── CORS ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# ─── Rate Limiting ──────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10

# ─── File Storage (Cloudinary – preferred, optional) ────────────────
# Sign up at https://cloudinary.com/ (free tier available)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── File Storage (AWS S3 – fallback, optional) ────────────────────
# Leave empty to use local uploads/ folder in dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# ─── Image Validation ──────────────────────────────────────────────
MAX_IMAGE_SIZE=5242880
